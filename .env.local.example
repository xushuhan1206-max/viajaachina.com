# ViajaAChina - Environment Variables

# Dify API Key (required for AI chat)
# Get it from: Dify Cloud → Your App → API Access → "API Key"
# Example: app-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DIFY_API_KEY=

# DeepSeek API Key (optional, used for direct API fallback)
DEEPSEEK_API_KEY=

